          "name": "Update Grade",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 92.0,\n  \"remarks\": \"Excellent improvement\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/grades/{{grade_id}}",
              "host": ["{{base_url}}"],
              "path": ["grades", "{{grade_id}}"]
            },
            "description": "Partially updates a grade. `letterGrade` is recomputed automatically from the new score. Returns 404 if grade not found."
          },
          "response": []
        },
        {
          "name": "Delete Grade",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/grades/{{grade_id}}",
              "host": ["{{base_url}}"],
              "path": ["grades", "{{grade_id}}"]
            },
            "description": "Permanently deletes a grade record. Returns 204 No Content on success."
          },
          "response": []
        }
      ]
