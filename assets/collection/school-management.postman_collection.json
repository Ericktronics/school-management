    },
    {
      "name": "Grades",
      "item": [
        {
          "name": "Get All Grades",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/grades",
              "host": ["{{base_url}}"],
              "path": ["grades"]
            },
            "description": "Returns all grades with student, subject, and class details. Sorted by createdAt DESC."
          },
          "response": []
        },
        {
          "name": "Get Grade by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/grades/{{grade_id}}",
              "host": ["{{base_url}}"],
              "path": ["grades", "{{grade_id}}"]
            },
            "description": "Returns a single grade record with full student, subject, and class relations."
          },
          "response": []
        },
        {
          "name": "Get Student Grade Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/grades/report/student/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["grades", "report", "student", "{{student_id}}"]
            },
            "description": "Returns a grade report for a student grouped by subject, including the average score per subject. Returns 404 if student not found."
          },
          "response": []
        },
        {
          "name": "Create Grade",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('grade_id', res.data.id);",
                  "  console.log('grade_id set to:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 88.5,\n  \"semester\": \"FIRST\",\n  \"academicYear\": \"2024-2025\",\n  \"studentId\": \"{{student_id}}\",\n  \"subjectId\": \"{{subject_id}}\",\n  \"classId\": \"{{class_id}}\",\n  \"remarks\": \"Good performance\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/grades",
              "host": ["{{base_url}}"],
              "path": ["grades"]
            },
            "description": "Creates a grade record. `semester` must be `FIRST` or `SECOND`. Score is 0–100 with up to 2 decimal places. `letterGrade` is computed automatically.\n\nAll three FK IDs (student, subject, class) must exist — returns 404 for any that don't.\n\nAutomatically saves the returned `id` to the `{{grade_id}}` collection variable."
          },
          "response": []
        },
