              "raw": "{\n  \"name\": \"Grade 8 - Section A\",\n  \"gradeLevel\": \"Grade 8\",\n  \"academicYear\": \"2024-2025\",\n  \"homeroomTeacherId\": \"{{teacher_id}}\"\n}",
